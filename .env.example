# Copy this file to .env and fill in real values.
# NEVER commit the real .env file — add it to .gitignore (already done).

# Deployer wallet private key — use a DEDICATED deploy wallet, never your main wallet.
# For testnet, this can hold a small amount of test ETH only.
PRIVATE_KEY=

# Optional: custom RPC URLs (defaults to public Base RPCs if left blank)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org

# Basescan API key, for contract verification (get one free at basescan.org)
BASESCAN_API_KEY=

# Optional: address to receive the protocol's share of swap fees
# (e.g. your veVERDI staking/treasury contract once it exists).
# Leave blank to keep the fee switch disabled at deploy time.
VERDI_FEE_TO=
